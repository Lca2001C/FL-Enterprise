# Database (Postgres connection string)
# Desenvolvimento na máquina host (Postgres em localhost:5432):
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/motopay
# Dentro dos containers Docker Compose, o serviço sobrescreve com host `db`.
# Para rodar só Postgres via Compose e a API no host, use localhost:5432 (porta publicada).

# JWT (obrigatório em produção: gere um valor forte e NUNCA commite .env)
# Ex.: py -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Redis (Celery broker / backend)
REDIS_URL=redis://localhost:6379/0

# Asaas — obrigatório para Pix/assinaturas e webhooks (sandbox: https://sandbox.asaas.com)
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# Telegram — obrigatório para o bot e notificações: crie o bot em @BotFather e cole o token
TELEGRAM_BOT_TOKEN=

# API (development vs production; CORS em produção exige origens explícitas)
ENVIRONMENT=development
# Lista separada por vírgula, ex.: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# API base URL (used by Streamlit and webhooks callbacks)
API_PUBLIC_BASE_URL=http://localhost:8000

# App timezone for scheduling (IANA)
APP_TIMEZONE=America/Sao_Paulo

# Streamlit: auto-refresh interval in seconds (0 = off)
STREAMLIT_REFRESH_SECONDS=60

