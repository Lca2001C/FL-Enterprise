# Database (PostgreSQL, SQLAlchemy + psycopg v3).
# Local/host: porta 5432. Use 5434 se outro Postgres ocupar 5432 (ver comentário no fim do arquivo).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/motopay

# Opcional Supabase: use URL do pool (:6543) em DATABASE_URL; para Alembic use conexão **direta** (host db.PROJECT.supabase.co :5432).
# DATABASE_MIGRATION_URL=postgresql+psycopg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require

# Pool da API (Railway/multi-worker: não exagerar versus o limite do Supabase/pg)
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Credenciais do Postgres para docker-compose apenas (Compose monta DATABASE_URL nos serviços app)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=motopay

# JWT (obrigatório em produção: gere um valor forte e NUNCA commite .env)
# Ex.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limit no login (por IP + e-mail, via Redis)
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
REFRESH_RATE_LIMIT_MAX_ATTEMPTS=20
REFRESH_RATE_LIMIT_WINDOW_SECONDS=900
WEBHOOK_RATE_LIMIT_MAX_ATTEMPTS=30
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=900

# Proxy reverso confiável (vírgula). Ex.: 127.0.0.1,172.16.0.0/16 — só então X-Forwarded-For é usado.
TRUSTED_PROXY_IPS=

# Redis (Celery broker/backend; rate-limit; refresh tokens). Upstash usa rediss://
REDIS_URL=redis://localhost:6379/0
# Senha do Redis no docker-compose prod (overlay docker-compose.prod.yml)
# REDIS_PASSWORD=
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_SOCKET_TIMEOUT_SECONDS=10
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# Telegram — obrigatório para o bot e notificações: crie o bot em @BotFather e cole o token
TELEGRAM_BOT_TOKEN=

# Mercado Pago — Pix, cartão (Orders API) e webhooks
# Guia completo: docs/MERCADOPAGO_SETUP.md | Validar: python scripts/mp_config_check.py
# Credenciais por operação: Ajustes no painel (token + public key + webhook secret)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
# development: test | production (sandbox usa MERCADOPAGO_*_TEST quando mode=test)
MERCADOPAGO_CREDENTIALS_MODE=test
MERCADOPAGO_ACCESS_TOKEN_TEST=
MERCADOPAGO_PUBLIC_KEY_TEST=
MERCADOPAGO_WEBHOOK_SECRET_TEST=
# Docker frontend build: Public Key do modo ativo (copie MERCADOPAGO_PUBLIC_KEY_TEST em dev)
MERCADOPAGO_VITE_PUBLIC_KEY=

# OAuth Mercado Pago (conectar conta da operação em Ajustes)
MERCADOPAGO_OAUTH_CLIENT_ID=
MERCADOPAGO_OAUTH_CLIENT_SECRET=
# Opcional; padrão: {API_PUBLIC_BASE_URL}/api/v1/operacoes/mp-oauth/callback
MERCADOPAGO_OAUTH_REDIRECT_URI=

# URL pública do painel (links do portal do pagador e redirect pós-OAuth)
# Ex.: http://localhost:5173 ou https://admin.exemplo.com
PAYER_PORTAL_BASE_URL=http://localhost:5173
# Validade do link público de pagamento (dias)
PAYER_PORTAL_TOKEN_TTL_DAYS=30

# Produção — exceções raras (documente antes de usar: staging ou integração ausente)
# ALLOW_PRODUCTION_WITHOUT_MERCADOPAGO=true
# ALLOW_PRODUCTION_WITHOUT_TELEGRAM=true

# Seeds: não rode em prod sem decisão explícita (motopay/config valida outros requisitos de prod)
# ALLOW_PRODUCTION_SEED=true

# API (development vs production; CORS em produção exige origens explícitas)
ENVIRONMENT=development
# Desenvolvimento: inclua a origem do admin React (Vite ou nginx no Compose), ex. http://localhost:5173
# Teste no celular (mesma Wi‑Fi): ./scripts/start.sh --lan (ajusta CORS e VITE_API_BASE_URL automaticamente)
# Produção: defina ao menos uma origem (URL completa), ex.: https://admin.exemplo.com
# Lista vazia em production = sem CORS cross-origin (seguro; front no mesmo host não precisa).
CORS_ORIGINS=http://localhost:5173

# API base URL (callbacks / documentação; o admin React usa VITE_API_BASE_URL na build)
API_PUBLIC_BASE_URL=http://localhost:8000

# Diretório de uploads locais (fotos de motos). Docker Compose monta volume em /data/uploads.
# UPLOAD_DIR=/data/uploads

# Admin React (Vite build): URL pública da API (navegador). Vercel: https://xxx.up.railway.app ou domínio custom.
# Docker Compose usa SAME_ORIGIN (nginx faz proxy de /api) — recomendado para PWA no celular na rede local.
# Railway injeta PORT no container da API — não precisa no .env local se usar uvicorn só em 8000.
VITE_API_BASE_URL=http://localhost:8000

# Vite dev local (opcional; apps/motopay-frontend/.env): Payment Brick sem esperar API
# VITE_MERCADOPAGO_PUBLIC_KEY=

# PWA — service worker no Vite dev (opcional; produção usa npm run build)
# VITE_PWA_DEV=true

# App timezone for scheduling (IANA)
APP_TIMEZONE=America/Sao_Paulo

# Celery beat — hora/minuto da automação diária (IANA timezone acima)
CELERY_BEAT_HOUR=11
CELERY_BEAT_MINUTE=0

# Observabilidade (opcional)
SENTRY_DSN=
METRICS_TOKEN=
LOG_LEVEL=INFO
WORKER_METRICS_PORT=9808
# Docker/Prometheus: use 0.0.0.0 so other containers can scrape; local dev default is 127.0.0.1
# WORKER_METRICS_HOST=0.0.0.0
CELERY_QUEUE_BACKLOG_THRESHOLD=100
CELERY_STUCK_TASK_SECONDS=600

# Stack local: docker compose -f docker-compose.yml -f docker-compose.observability.yml up
# Produção local/simulada: docker compose -f docker-compose.yml -f docker-compose.prod.yml up
#   (exige POSTGRES_PASSWORD e REDIS_PASSWORD fortes no .env; Redis sem porta pública)
# Grafana: http://localhost:3000 (admin/admin) | Prometheus: http://localhost:9090

# Bot Telegram — IA opcional (/ajuda)
OPENAI_API_KEY=
AI_BOT_ENABLED=false

# Postgres alternativo local (evita conflito com outro serviço na 5432):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/motopay
# docker run --name motopay-migrate-db -e POSTGRES_PASSWORD=postgres -p 5434:5432 -d postgres:16-alpine

