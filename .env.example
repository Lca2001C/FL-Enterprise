# Database (Postgres connection string)
# Desenvolvimento na máquina host (Postgres em localhost:5432):
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/motopay
# Dentro dos containers Docker Compose, o DATABASE_URL dos serviços app usa host `db` e
# usuário/senha/banco definidos abaixo (interpolação do docker-compose). Alinhe DATABASE_URL
# local a estes valores se usar o mesmo Postgres (ex.: docker compose + API no host).

# Credenciais do Postgres (usadas pelo docker-compose na montagem do DATABASE_URL dos containers;
# também use as mesmas em DATABASE_URL acima se conectar ao mesmo banco)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=motopay

# JWT (obrigatório em produção: gere um valor forte e NUNCA commite .env)
# Ex.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Redis (Celery broker / backend)
REDIS_URL=redis://localhost:6379/0

# Asaas — obrigatório para Pix/assinaturas e webhooks (sandbox: https://sandbox.asaas.com)
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# Telegram — obrigatório para o bot e notificações: crie o bot em @BotFather e cole o token
TELEGRAM_BOT_TOKEN=

# API (development vs production; CORS em produção exige origens explícitas)
ENVIRONMENT=development
# Desenvolvimento: inclua a origem do admin React (Vite ou nginx no Compose), ex. http://localhost:5173
# Produção: defina ao menos uma origem (URL completa), ex.: https://admin.exemplo.com
# Lista vazia em production = sem CORS cross-origin (seguro; front no mesmo host não precisa).
CORS_ORIGINS=http://localhost:5173

# API base URL (callbacks / documentação; o admin React usa VITE_API_BASE_URL na build)
API_PUBLIC_BASE_URL=http://localhost:8000

# Admin React (Vite): URL da API como o *navegador* acessa (host + porta publicados, não o hostname interno do Compose).
# No Docker, com API em localhost:8000 no host: use http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# App timezone for scheduling (IANA)
APP_TIMEZONE=America/Sao_Paulo

